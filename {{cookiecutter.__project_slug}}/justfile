set windows-shell := ["powershell.exe", "-NoLogo", "-Command"]

@default:
	just --list

# Deployment commands

deploy_on_{{cookiecutter.__ssh_slug}}:
	uv run manage.py tailwind build
	uv run manage.py collectstatic --noinput
	-git remote add origin {{cookiecutter.server_ssh_name}}:/root/dpgstack/projects/{{cookiecutter.__project_slug}}/{{cookiecutter.__project_slug}}_bare_repo
	git push origin main
	-docker stop dpgstack-ansible
	-docker rm dpgstack-ansible
	docker run --network=host --name dpgstack-ansible -d willhallonline/ansible:latest tail -f /dev/null
	docker cp $HOME/.ssh dpgstack-ansible:/root/.ssh
	docker cp ./deploy/deploy_{{cookiecutter.__project_slug}} dpgstack-ansible:/root/deploy
	docker cp ./deploy/deploy_{{cookiecutter.__project_slug}}/nginx dpgstack-ansible:/root/nginx_master
	docker cp ./staticfiles dpgstack-ansible:/root/staticfiles
	docker exec -it dpgstack-ansible chown root:root /root/.ssh/config
	docker exec -it dpgstack-ansible chmod -R 600 /root/.ssh
	docker exec -it dpgstack-ansible ansible-playbook -i /root/deploy/ansible/hosts.yml /root/deploy/ansible/playbook.yml

c:
	git add .
	-git commit -m 22
	git push origin main


deploy_on_localhost:
	uv run manage.py tailwind build
	uv run manage.py collectstatic --noinput
	git init --initial-branch=main --bare deploy/deploy_on_localhost/jenkins/{{cookiecutter.__project_slug}}_bare_repo
	-git remote add local ./deploy/deploy_on_localhost/jenkins/{{cookiecutter.__project_slug}}_bare_repo
	docker compose -p {{cookiecutter.__project_slug}}_on_localhost -f deploy/deploy_on_localhost/compose.yaml up --build -d	

c-l:
	git add .
	-git commit -m 22
	git push local main

# Development helper commands:

# Suit the Model: migrate it, create CRUD parts for it, populate it with mock data

# just suit-simple Client clients table
suit-simple model app layout: migrate
    uv run manage.py suit_model {% raw %}{{model}} "{{app}}"{% endraw %} --layout {% raw %}{{layout}}{% endraw %} --overwrite
    just populate {% raw %}{{model}} {{app}}{% endraw %}

# just suit-fk Author Book books table
suit-fk parent child app layout: migrate
    uv run manage.py suit_model {% raw %}{{parent}} "{{app}}"{% endraw %} --layout {% raw %}{{layout}}{% endraw %} --overwrite
    uv run manage.py suit_model {% raw %}{{child}} "{{app}}"{% endraw %} --layout {% raw %}{{layout}}{% endraw %} --overwrite
    just populate {% raw %}{{parent}} {{app}}{% endraw %}
    just populate {% raw %}{{child}} {{app}}{% endraw %}

# Un-suit the Model: remove CRUD parts generated by suit_model

# just unsuit-simple Client clients
unsuit-simple model app:
    uv run manage.py unsuit_model {% raw %}{{model}} "{{app}}"{% endraw %}

# just unsuit-fk Author Book books
unsuit-fk child parent app:
    uv run manage.py unsuit_model {% raw %}{{parent}} "{{app}}"{% endraw %}
    uv run manage.py unsuit_model {% raw %}{{child}} "{{app}}"{% endraw %}

populate model app count="10":
    uv run manage.py populate {% raw %}{{app}}.{{model}} {{count}}{% endraw %}

down:
	docker compose -p deploy_{{cookiecutter.__project_slug}}_on_localhost -f deploy/deploy_on_localhost/compose.yaml down -v --rmi all --remove-orphans

ps:
	docker compose -p deploy_{{cookiecutter.__project_slug}}_on_localhost -f deploy/deploy_on_localhost/compose.yaml ps

restart:
	docker compose -p deploy_{{cookiecutter.__project_slug}}_on_localhost -f deploy/deploy_on_localhost/compose.yaml restart


jenkins_bash:
	docker compose -p deploy_{{cookiecutter.__project_slug}}_on_localhost -f deploy/deploy_on_localhost/compose.yaml exec -it jenkins bash

up:
	docker compose -p deploy_{{cookiecutter.__project_slug}}_on_localhost -f deploy/deploy_on_localhost/compose.yaml up --build -d

shell:
	uv run manage.py shell_plus

migrate:
	uv run manage.py makemigrations
	uv run manage.py migrate
	
hns-restart:
	Start-Process -Verb RunAs -FilePath "cmd.exe" -ArgumentList "/c", "net stop hns && net start hns && pause"

check:
	uv run manage.py check