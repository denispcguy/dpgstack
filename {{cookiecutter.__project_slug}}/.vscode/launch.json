{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "django",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "runserver",
                "0.0.0.0:8000"
            ],
            "django": true,
            "autoStartBrowser": false,
            "program": "${workspaceFolder}/manage.py",
            "justMyCode": false,
            "preLaunchTask": "Build",
            "postDebugTask": "Stop",
            "envFile": "${workspaceFolder}/.env",
        }
    ]
}